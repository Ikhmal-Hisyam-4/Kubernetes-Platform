# Example Terraform Variables for Lab Environment
# Copy this file to terraform.tfvars and fill in your values

# Harvester Configuration
harvester_kubeconfig = "~/.kube/harvester-config"

# Rancher Configuration
rancher_url      = "https://rancher.lab.robusthpc.local"
rancher_token    = "token-xxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxx"
rancher_insecure = true

# RKE2 Cluster Configuration
rke2_kubeconfig = "~/.kube/rke2-config"

# VM Configuration
vm_namespace  = "default"
vm_network    = "vm-network"
storage_class = "longhorn"

# SSH Public Key (paste your public key here)
ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQ... user@host"

# RKE2 Control Plane VM
rke2_control_plane = {
  count  = 1
  cpu    = 4
  memory = "8Gi"
  disk   = "100Gi"
}

# RKE2 Worker VMs
rke2_workers = {
  count  = 2
  cpu    = 8
  memory = "16Gi"
  disk   = "200Gi"
}

# VM Image
vm_image = {
  name         = "ubuntu-22.04"
  display_name = "Ubuntu 22.04 LTS"
  url          = "https://cloud-images.ubuntu.com/releases/22.04/release/ubuntu-22.04-server-cloudimg-amd64.img"
}

